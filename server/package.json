{
  "name": "2kbridge-server",
  "version": "1.0.0",
  "description": "2KBridge backend – lobby, auth, chat, WebRTC signaling",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dist": "pkg src/index.js --targets node18-win-x64 --output dist/2KBridge-Server.exe"
  },
  "pkg": {
    "scripts": [
      "../shared/**/*.js"
    ],
    "assets": [
      "../shared/**/*.json"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "pkg": "^5.8.1"
  }
}
